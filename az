#!/bin/bash

# Set variables (update these with your own values)
resourceGroupName="entraid"
vmName="myIdentityVM"
storageAccountName="mithunstorage1458"  # Must be globally unique
containerName="entraid-098"
location="CENTRALINDIA"
adminUsername="azureuser"  # Replace with your desired admin username
adminPassword="Linux@786$#$"  # Use a strong password or SSH key


connectionString=$(az storage account show-connection-string \
    --resource-group $resourceGroupName \
    --name $storageAccountName \
    --query connectionString -o tsv)

    
# 1. Create a resource group
az group create --name $resourceGroupName --location $location

# 2. Create a Linux VM with system-assigned managed identity enabled
echo "Creating VM with system-assigned managed identity..."
az vm create \
    --resource-group $resourceGroupName \
    --name $vmName \
    --image Ubuntu2204 \
    --size Standard_D2s_v5 \
    --admin-username $adminUsername \
    --admin-password $adminPassword \
    --assign-identity \
    --generate-ssh-keys # Use this for SSH key authentication instead of password

# 3. Create a storage account
echo "Creating storage account..."
az storage account create \
    --resource-group $resourceGroupName \
    --name $storageAccountName \
    --location $location \
    --sku Standard_LRS

# 4. Create a blob container
echo "Creating blob container..."
az storage container create \
    --account-name $storageAccountName \
    --name $containerName \
    --auth-mode login


+++++++++++++++++++++++++++++
# Create a sample file
echo "Hello World from Managed Identity!" > sample.txt

# Get the storage account connection string
connectionString=$(az storage account show-connection-string \
    --resource-group $resourceGroupName \
    --name $storageAccountName \
    --query connectionString -o tsv)

# Upload the file to the blob container
az storage blob upload \
    --connection-string $connectionString \
    --container-name $containerName \
    --name sample.txt \
    --file sample.txt

echo "Sample file uploaded to blob container."
++++++++++++++++++++++
# Get the VM's system-assigned managed identity principal ID
spID=$(az vm show --resource-group $resourceGroupName --name $vmName --query identity.principalId -o tsv)

# Get the storage account resource ID
storageId=$(az storage account show --resource-group $resourceGroupName --name $storageAccountName --query id -o tsv)

# Assign the "Storage Blob Data Reader" role to the managed identity at the storage account scope
az role assignment create \
    --assignee $spID \
    --role "Storage Blob Data Reader" \
    --scope $storageId

echo "Role assignment complete. The VM can now read blobs from the storage account."
